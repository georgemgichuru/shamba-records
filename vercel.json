{
  "buildCommand": "cd coreui-free-react-admin-template && npm install && npm run build",
  "outputDirectory": "coreui-free-react-admin-template/build",
  "devCommand": "cd coreui-free-react-admin-template && npm run dev",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
